{
  "name": "ecommerce-image-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.14.0 <25.0.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "prebuild": "node scripts/generate-build-metadata.mjs",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "lint": "tsc --noEmit",
    "preview:full": "node scripts/start-local-preview.mjs",
    "check:production": "node scripts/check-production.mjs",
    "secret:internal-billing": "node scripts/generate-production-secret.mjs internal-billing-key",
    "secret:auth-code": "node scripts/generate-production-secret.mjs auth-code-secret"
  },
  "dependencies": {
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "undici": "^7.28.0"
  }
}
